# ====================================================
# Variables de entorno para Control Pedidos
# Copiar este archivo como .env y rellenar los valores
# ====================================================

# Entorno (development / production)
NODE_ENV=production

# Puerto (Railway lo asigna automáticamente con $PORT)
# No es necesario definirlo aquí

# Base de datos MySQL (URL de conexión completa)
# Formato: mysql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=mysql://root:password@localhost:3306/control_pedidos

# Seguridad para cookies de sesión
JWT_SECRET=cambia_esto_por_una_clave_aleatoria_larga

# OAuth (opcional, solo si usas login social)
# OAUTH_SERVER_URL=
# OWNER_OPEN_ID=
